{
  "name": "wico-playwright-agent-skills",
  "version": "1.2.0",
  "description": "wico — Playwright Agent Skills for AI-assisted E2E testing",
  "type": "module",
  "bin": {
    "wico-playwright-agent-skills": "dist/bin/init.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx bin/init.ts",
    "lint": "tsc --noEmit",
    "test": "tsx --test tests/*.test.ts",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "files": [
    "dist",
    "skills"
  ],
  "keywords": [
    "playwright",
    "e2e",
    "testing",
    "agent",
    "ai",
    "claude",
    "cursor",
    "copilot",
    "skills"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/willcoliveira/qualiow-playwright-skills.git"
  },
  "homepage": "https://github.com/willcoliveira/qualiow-playwright-skills#readme",
  "bugs": {
    "url": "https://github.com/willcoliveira/qualiow-playwright-skills/issues"
  },
  "author": "William Oliveira",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
